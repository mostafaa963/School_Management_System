@model UpdateSubjectVM

@{
    ViewData["Title"] = "Update Subject";
}

## Update Subject

<div class="row">
    <div class="col-md-6">
        <form asp-action="Update" method="post">
            <input type="hidden" asp-for="SubjectID" />

            <div class="form-group mb-3">
                <label asp-for="SubjectName" class="control-label fw-bold"></label>
                <input asp-for="SubjectName" class="form-control" />
                <span asp-validation-for="SubjectName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SubjectCode" class="control-label fw-bold"></label>
                <input asp-for="SubjectCode" class="form-control" />
                <span asp-validation-for="SubjectCode" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}