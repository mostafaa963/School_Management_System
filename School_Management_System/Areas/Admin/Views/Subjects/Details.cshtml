@model Subject

@{
    ViewData["Title"] = "Subject Details";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="card-title mb-0">Subject Details</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <ul class="list-group list-group-flush">
                        
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Subject Name:</strong>
                            <span>@Model.SubjectName</span>
                        </li>

                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Subject Code:</strong>
                            <span class="badge bg-secondary px-3 py-2 fs-6">@Model.SubjectCode</span>
                        </li>

                    </ul>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light">
            <a asp-action="Update" asp-route-id="@Model.SubjectID" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
        </div>
    </div>
</div>