@model TeacherDetailsVM

@{
    ViewData["Title"] = "Teacher Details";
}

<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            
            <div class="mb-4 d-flex align-items-center justify-content-between">
                <div>
                    <h2 class="text-dark fw-bold mb-1 tracking-tight">Teacher Profile Details</h2>
                    <p class="text-muted small mb-0">Overview of the instructor's background, qualifications, and core system records.</p>
                </div>
                <div class="bg-primary text-white p-3 rounded-circle d-none d-sm-block shadow-sm">
                    <i class="bi bi-person-bounding-box fs-3line-height-1"></i>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
                <div class="card-header bg-dark py-3 px-4 d-flex align-items-center justify-content-between border-0">
                    <h5 class="text-white mb-0 fw-medium">
                        <i class="bi bi-card-text me-2 opacity-75"></i>Personal & Professional Profile
                    </h5>
                    <span class="badge bg-primary px-3 py-2 fw-semibold">Active Instructor</span>
                </div>
                
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 text-dark">
                            <tbody>
                                <tr>
                                    <td class="w-25 bg-light ps-4 fw-semibold text-muted small py-3 text-uppercase tracking-wider">Full Name</td>
                                    <td class="ps-4 fw-bold fs-5 text-dark py-3">
                                        @Model.FirstName @Model.LastName
                                    </td>
                                </tr>
                                
                                <tr>
                                    <td class="bg-light ps-4 fw-semibold text-muted small py-3 text-uppercase tracking-wider">Qualification</td>
                                    <td class="ps-4 py-3">
                                        <span class="badge bg-info text-dark px-3 py-2 fs-7 fw-medium rounded-pill">
                                            <i class="bi bi-mortarboard-fill me-1"></i> @(string.IsNullOrEmpty(Model.Qualification) ? "Not Specified" : Model.Qualification)
                                        </span>
                                    </td>
                                </tr>
                                
                                <tr>
                                    <td class="bg-light ps-4 fw-semibold text-muted small py-3 text-uppercase tracking-wider">Phone Number</td>
                                    <td class="ps-4 py-3 text-secondary font-monospace">
                                        <i class="bi bi-telephone me-2 text-muted"></i>@(string.IsNullOrEmpty(Model.PhoneNumber) ? "N/A" : Model.PhoneNumber)
                                    </td>
                                </tr>
                                
                                <tr>
                                    <td class="bg-light ps-4 fw-semibold text-muted small py-3 text-uppercase tracking-wider">Hire Date</td>
                                    <td class="ps-4 py-3 text-dark fw-medium">
                                        <i class="bi bi-calendar3 me-2 text-primary opacity-75"></i>@Model.HireDate.ToString("MMMM dd, yyyy")
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer bg-light p-4 border-0 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-3 fw-medium">
                        <i class="bi bi-arrow-left me-1"></i> Back to List
                    </a>
                    <a asp-action="Update" asp-route-id="@Context.Request.RouteValues["id"]" class="btn btn-warning text-dark px-4 py-2 rounded-3 fw-medium shadow-sm">
                        <i class="bi bi-pencil-square me-1"></i> Edit Profile
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>