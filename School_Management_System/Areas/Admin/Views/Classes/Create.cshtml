@model CreateClassVM

@{
    ViewData["Title"] = "Create New Class";
}

<div class="container-fluid pt-4">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-2">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
        <h2 class="text-primary fw-bold mb-1">Add New Class Structure</h2>
        <p class="text-muted small">Set up a new classroom grade level, section identifier, seat limits, and initial assignments.</p>
    </div>

    <div class="row">
        <div class="col-xl-8 col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" id="createClassForm">
                        
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ClassName" class="form-label fw-semibold">Class / Grade Name</label>
                                <input asp-for="ClassName" class="form-control" placeholder="e.g., Grade 10, Year 11" autofocus />
                                <span asp-validation-for="ClassName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="Section" class="form-label fw-semibold">Section / Room</label>
                                <input asp-for="Section" class="form-control" placeholder="e.g., A, B" />
                                <span asp-validation-for="Section" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="Capacity" class="form-label fw-semibold">Maximum Capacity</label>
                                <div class="input-group">
                                    <input asp-for="Capacity" class="form-control" type="number" min="1" max="200" />
                                    <span class="input-group-text bg-light text-muted">Seats</span>
                                </div>
                                <span asp-validation-for="Capacity" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4 d-flex align-items-center gap-2">
                                <i class="bi bi-save"></i> Save Class
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}