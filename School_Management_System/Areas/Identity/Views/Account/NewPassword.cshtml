@model NewPasswordVM
@{
    ViewData["Title"] = "Reset Password";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-dark mb-2">Create New Password</h2>
                        <p class="text-muted small">Your identity has been verified. Enter your new secure password below.</p>
                    </div>
                    
                    <form asp-action="NewPassword" method="post" autocomplete="off">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Password" type="password" class="form-control" placeholder="New Password" required />
                            <label asp-for="Password">New Password</label>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" required />
                            <label asp-for="ConfirmPassword">Confirm New Password</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <button type="submit" class="btn btn-success w-100 py-25 rounded-3 fw-semibold shadow-sm">
                            Reset Password
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_Notification" />
}