@model LoginVM
@{
    ViewData["Title"] = "Log in";
}
@section Scripts {
    <!-- Enables instant client-side validation before hitting the server -->
    <partial name="_ValidationScriptsPartial" />
    <partial name="_Notification" />
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-4 p-sm-5">
                    
                    <h3 class="card-title text-center mb-4 fw-bold">Sign In</h3>
                    
                    <form asp-action="Login" method="post">
                        <!-- Summary for global errors (e.g., "Invalid credentials") -->
                        <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

                        <!-- Username / Email Field -->
                        <div class="form-floating mb-3">
                            <input asp-for="EmailOrUserName" class="form-control" id="floatingInput" placeholder="name@example.com or username" />
                            <label asp-for="EmailOrUserName"></label>
                            <span asp-validation-for="EmailOrUserName" class="text-danger small"></span>
                        </div>

                        <!-- Password Field -->
                        <div class="form-floating mb-3">
                            <input asp-for="Pssword" class="form-control" id="floatingPassword" placeholder="Password" />
                            <label asp-for="Pssword">Password</label>
                            <span asp-validation-for="Pssword" class="text-danger small"></span>
                        </div>

                        <!-- Remember Me Checkbox -->
                        <div class="form-check mb-4">
                            <input asp-for="IsPersistent" class="form-check-input" type="checkbox" id="rememberMe" />
                            <label asp-for="IsPersistent" class="form-check-label" for="rememberMe">
                                Remember me?
                            </label>
                        </div>

                        <!-- Submit Button -->
                        <button class="btn btn-primary w-100 py-2 fw-semibold" type="submit">Log In</button>
                        <div class="text-center mt-4"> <span class="text-muted"> Don't have an account? </span> <a asp-action="Register" asp-controller="Account" class="fw-semibold text-decoration-none"> Create one </a> </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
