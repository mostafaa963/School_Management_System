@model ConfirmOtpVM
@{
    ViewData["Title"] = "Verify OTP";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-dark mb-2">Security Verification</h2>
                        <p class="text-muted small">Please type the security authorization code sent to your registered account.</p>
                    </div>
                    
                    <form asp-action="VerifyOTP" method="post" autocomplete="off">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                        
                        <div class="mb-4">
                            <label asp-for="OtpNumber" class="form-label fw-semibold text-secondary small mb-2">One-Time Password (OTP)</label>
                            <input asp-for="OtpNumber"
                                   class="form-control text-center fw-bold letter-spacing-lg fs-3 py-2 rounded-3 text-primary"
                                   placeholder="••••••"
                                   maxlength="6"
                                   required />
                            <span asp-validation-for="OtpNumber" class="text-danger small mt-1 d-block text-center"></span>
                        </div>
                        
                        <button type="submit" class="btn btn-warning w-100 py-25 rounded-3 fw-semibold shadow-sm text-dark mb-3">
                            Verify & Proceed
                        </button>
                        
                        <div class="text-center">
                            <a asp-action="ForgetPassword" asp-controller="Account" class="text-decoration-none small fw-medium text-secondary">
                                Resend Code
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_Notification" />
}