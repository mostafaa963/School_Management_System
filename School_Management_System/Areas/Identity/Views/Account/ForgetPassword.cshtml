@model ForgetPasswordVM
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-dark mb-2">Forgot Password?</h2>
                        <p class="text-muted small">Enter your registered Email or Username below, and we will send you an OTP to reset your password.</p>
                    </div>
                    
                    <form asp-action="ForgetPassword" method="post" autocomplete="off">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="EmailOrUserName" class="form-control" placeholder="name@example.com or username" required />
                            <label asp-for="EmailOrUserName"></label>
                            <span asp-validation-for="EmailOrUserName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 py-25 rounded-3 fw-semibold shadow-sm mb-3">
                            Send OTP Code
                        </button>
                        
                        <div class="text-center">
                            <a asp-action="Login" asp-controller="Account" class="text-decoration-none small fw-medium text-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Back to Sign In
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_Notification" />
}